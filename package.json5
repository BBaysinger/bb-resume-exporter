{
  // Package name used for local tooling and npm metadata.
  "name": "resume-export",
  // Project version kept in sync with generated outputs and releases.
  "version": "1.0.0",
  // Prevents accidental publication of this private resume workspace.
  "private": true,
  // Development-only tools used to sync and format manifest files.
  "devDependencies": {
    // Maintains this documented JSON5 companion from canonical package.json.
    "json5-manifest-sync": "^0.2.1",
    // Formats repo sources and markdown content consistently.
    "prettier": "^3.8.3",
  },
  // Prettier settings tailored for this repository's script layout.
  "prettier": {
    // Use Babel parsing for .mjs utility scripts.
    "overrides": [
      // Match ES module helper scripts in the repo root.
      {"files":["*.mjs"],"options":{"parser":"babel"}},
    ],
  },
  // Common workflows for exporting resumes and maintaining source files.
  "scripts": {
    // Render the active resume source into HTML.
    "build:html": "node scripts/resume.mjs build-html",
    // Run the full conversion pipeline across available inputs.
    "convert:all": "node scripts/convert-all.mjs",
    // Convert only markdown inputs changed since the last input-repo commit.
    "convert:changed": "node scripts/convert-all.mjs --changedSince HEAD",
    // Generate an email draft from the current resume materials.
    "draft:email": "node scripts/draft-email.mjs",
    // Export the resume as a PDF document.
    "export:pdf": "node scripts/resume.mjs export-pdf",
    // Export the resume as a DOCX document.
    "export:docx": "node scripts/resume.mjs export-docx",
    // Normalize markdown unicode characters in the input directory.
    "normalize:md": "python3 scripts/input/_scripts/normalize_markdown_unicode.py --write input",
    // Check whether markdown unicode normalization would make changes.
    "normalize:md:check": "python3 scripts/input/_scripts/normalize_markdown_unicode.py --check input",
    // Run formatting, then resync package.json5 before committing changes.
    "precommit": "npm run format && npm run sync:json5",
    // Install git hooks for input content maintenance.
    "setup:input-hooks": "bash scripts/input/_scripts/setup-hooks.sh",
    // Format the repository while respecting the shared ignore list.
    "format": "prettier --write . --ignore-path .prettierignore",
    // Verify repository formatting without modifying files.
    "format:check": "prettier --check . --ignore-path .prettierignore",
    // Format only markdown resume inputs with the dedicated config.
    "format:md": "prettier --config .prettierrc.json --write \"input/**/*.md\"",
    // Check markdown resume inputs against the dedicated config.
    "format:md:check": "prettier --config .prettierrc.json --check \"input/**/*.md\"",
    // Sync package.json5 comments and structure from the canonical JSON manifest.
    "sync:json5": "json5-manifest-sync --blank-comments=fill",
  },
}